# ===========================================================================
# Database — Neon Postgres (REQUIRED for a real deployment)
# Neon Console -> your project -> Connection string (pooled).
# Format: postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
# When DATABASE_URL is absent the app runs in demo mode (sample dataset).
# ===========================================================================
DATABASE_URL=postgresql://user:password@your-endpoint.neon.tech/neondb?sslmode=require

# ===========================================================================
# Admin login (REQUIRED) — password + signed cookie. Only you can sign in.
#   * ADMIN_PASSWORD : the admin password (a strong secret). OR
#   * ADMIN_PASSWORD_HASH : sha256 hex of the password (use instead of plaintext)
#     e.g.  printf 'mypassword' | shasum -a 256
#   * SESSION_SECRET : long random string used to sign the session cookie.
#     e.g.  openssl rand -hex 32   (rotating it logs you out)
# ===========================================================================
ADMIN_PASSWORD=change-me-to-a-strong-password
# ADMIN_PASSWORD_HASH=
SESSION_SECRET=change-me-to-a-long-random-secret

# ===========================================================================
# Admin 2FA — Telegram one-time code (OPTIONAL, recommended)
# When BOTH are set (and DATABASE_URL is configured), a correct password no
# longer logs you in directly: a 6-digit code is sent to your Telegram and
# must be entered to finish. This stops a leaked/guessed password alone from
# granting access. Login is also rate-limited per IP either way.
#   * Create a bot with @BotFather → TELEGRAM_BOT_TOKEN.
#   * Get your chat id (message the bot, then read it from
#     https://api.telegram.org/bot<TOKEN>/getUpdates) → TELEGRAM_ADMIN_CHAT_ID.
# Leave both unset to keep password-only login (e.g. local/demo).
#
# The SAME bot also powers slash commands (/boost /trend /speed /list) via a
# webhook. Set TELEGRAM_WEBHOOK_SECRET to a random string, then register it once:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#     -d url="https://<your-domain>/api/telegram/webhook" \
#     -d secret_token="<TELEGRAM_WEBHOOK_SECRET>"
# ===========================================================================
# TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token
# TELEGRAM_ADMIN_CHAT_ID=-1001234567890
# TELEGRAM_WEBHOOK_SECRET=$(openssl rand -hex 24)

# ===========================================================================
# Cron — periodic synthetic growth (OPTIONAL). A GitHub Actions workflow
# (.github/workflows/grow.yml) POSTs to /api/cron/grow every ~5 min and nudges
# each shop's synthetic counts up a little. Set CRON_SECRET to a random string
# in BOTH Vercel (env) and the GitHub repo (Settings → Secrets → CRON_SECRET).
# ===========================================================================
# CRON_SECRET=$(openssl rand -hex 24)

# ===========================================================================
# Cloudflare R2 — image storage (thumbnails). DB stores only the public URL.
# Cloudflare dashboard -> R2 -> create bucket + an S3 API token.
# R2_PUBLIC_BASE_URL is the bucket's public URL (r2.dev) or a custom domain.
# If R2 is not set, admin can still paste an image URL directly (no upload).
# ===========================================================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=anor-thumbnails
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# ===========================================================================
# Google Maps
# https://console.cloud.google.com -> APIs & Services -> Credentials
# Enable "Maps JavaScript API" and restrict the key to your domains.
# ===========================================================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===========================================================================
# Public site URL + allowed origins.
# NEXT_PUBLIC_SITE_URL powers robots.txt / sitemap and is treated as an allowed
# origin for the write APIs (likes / views / search-log). Add any extra origins
# (e.g. a custom domain) to ALLOWED_ORIGINS, comma-separated.
# ===========================================================================
NEXT_PUBLIC_SITE_URL=https://hellomyeongdong.com
# ALLOWED_ORIGINS=https://www.your-domain.com,https://your-domain.vercel.app

# ===========================================================================
# IP hashing salt — set to a long random string in production.
# Likes are deduped by sha256(IP + salt); the raw IP is never stored. Rotating
# this salt resets all like/dedupe state. e.g. `openssl rand -hex 32`
# ===========================================================================
IP_HASH_SALT=change-me-to-a-long-random-secret

# ===========================================================================
# Rate limiting (optional but recommended for production on serverless).
# If set, likes/views/search-log are rate-limited per IP via Upstash Redis
# (shared across all instances). If unset, an in-memory per-instance limiter
# is used as a best-effort fallback. Create a free DB at https://upstash.com.
# ===========================================================================
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-rest-token

# ===========================================================================
# Demo mode (optional)
# When set to 1 AND no DATABASE_URL is configured, public pages render a
# built-in sample dataset (lib/demo-data.ts) instead of an empty state.
# Useful for previews / screenshots. Leave unset in real deployments.
# ===========================================================================
# NEXT_PUBLIC_DEMO_MODE=1
