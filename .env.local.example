# ===========================================================================
# Supabase
# Project Settings -> API
# ===========================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. NEVER expose this to the browser. Used by admin server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================================================
# Kakao Maps
# https://developers.kakao.com -> My Application -> JavaScript Key
# Register your site domain under Platform -> Web (e.g. http://localhost:3000)
# ===========================================================================
NEXT_PUBLIC_KAKAO_MAP_KEY=your-kakao-javascript-key

# ===========================================================================
# Supabase Storage bucket used for thumbnail uploads (created by README steps)
# ===========================================================================
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=food-thumbnails
