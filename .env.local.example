# ===========================================================================
# Supabase
# Project Settings -> API
# ===========================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. NEVER expose this to the browser. Used by admin server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================================================
# Google Maps
# https://console.cloud.google.com -> APIs & Services -> Credentials
# Enable "Maps JavaScript API" and restrict the key to your domains.
# ===========================================================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===========================================================================
# Supabase Storage bucket used for thumbnail uploads (created by README steps)
# ===========================================================================
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=food-thumbnails

# ===========================================================================
# Demo mode (optional)
# When set to 1 AND Supabase is not configured, the public pages render a
# built-in sample dataset (lib/demo-data.ts) instead of an empty state.
# Useful for previews / screenshots. Leave unset in real deployments.
# ===========================================================================
# NEXT_PUBLIC_DEMO_MODE=1
